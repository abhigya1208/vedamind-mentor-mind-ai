# VedaMind Backend Environment Variables
# Copy this to .env and fill in values

PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# PRIMARY: SQLite
DATABASE_URL="file:./vedamind.db"

# FALLBACK: MongoDB (uncomment to switch)
# MONGO_URI=mongodb://localhost:27017/vedamind

# Leave EMPTY for MOCK mode — set key for live OpenAI responses
OPENAI_API_KEY=

# Mock auth secret — replace with strong value in production
JWT_SECRET=devsecret-change-me
